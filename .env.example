# LumenHorizon local development settings.
# Copy this file to .env and replace secrets/placeholders as needed.

PORT=8083
RUST_LOG=ingest_svc=info

# API Gateway local shell. These values are placeholders for local route and auth
# middleware development; use profile-specific Entra ID values outside local mode.
API_GATEWAY_PORT=8080
API_GATEWAY_RUST_LOG=api_gateway=info
RUNTIME_ENVIRONMENT=local
RATE_LIMIT_BACKEND=memory
# Required when RATE_LIMIT_BACKEND=redis, and outside local/dev profiles.
# REDIS_URL=redis://localhost:6379
JWT_ISSUER=https://login.microsoftonline.com/common/v2.0
JWT_AUDIENCE=api://lumenhorizon-admin
JWKS_URL=https://login.microsoftonline.com/common/discovery/v2.0/keys
# Required outside local/dev profile. Set to the concrete Microsoft Entra tenant id that
# must match the token `tid` claim; do not use common/organizations/consumers.
# JWT_TENANT_ID=11111111-1111-1111-1111-111111111111
ADMIN_ROLE_CLAIM=roles
ADMIN_REQUIRED_ROLE=lumenhorizon.admin
JWKS_CACHE_TTL_SECONDS=300
JWT_CLOCK_SKEW_SECONDS=60
JWT_MAX_ADMIN_TOKEN_LIFETIME_SECONDS=3600
INGEST_SERVICE_BASE_URL=http://localhost:8083
# Required outside local/dev profile when the gateway calls internal admin endpoints.
# Set the same value on api-gateway and ingest-svc; keep it out of logs.
# INTERNAL_SERVICE_AUTH_TOKEN=replace-with-at-least-32-random-characters
# INTERNAL_SERVICE_AUTH_HEADER=x-lumenhorizon-internal-token
TILE_LATEST_CACHE_CONTROL="public, max-age=300, must-revalidate"
MAX_URL_LENGTH_BYTES=8192
ADMIN_MAX_BODY_BYTES=65536
PUBLIC_ROUTE_TIMEOUT_SECONDS=5
ADMIN_ROUTE_TIMEOUT_SECONDS=15
HEALTH_ROUTE_TIMEOUT_SECONDS=2

DATABASE_URL=postgresql://lumenhorizon:lumenhorizon@localhost:5432/lumenhorizon
DATABASE_MAX_CONNECTIONS=5

# Azurite local storage emulator defaults.
AZURE_STORAGE_ACCOUNT=devstoreaccount1
AZURE_STORAGE_ACCESS_KEY=Eby8vdM02xNOcqFlqUwJPLlmEtlCDXJ1OUzFT50uSRZ6IFsuFq2UVErCz4I6tq/K1SZFPTOtr/KBHBeksoGMGw==
AZURE_STORAGE_EMULATOR_HOST=127.0.0.1
AZURE_QUEUE_NAME=viirs-processing
AZURE_DEADLETTER_QUEUE_NAME=viirs-processing-deadletter
HTTP_REQUEST_TIMEOUT_SECONDS=30
HTTP_RETRY_MAX_ATTEMPTS=3
HTTP_RETRY_BASE_DELAY_MS=250
HTTP_RETRY_MAX_DELAY_MS=5000

# Required for real NASA Earthdata downloads. Leave as a placeholder until needed.
EARTHDATA_BEARER_TOKEN=replace-me

# Use a narrower BOUNDING_BOX for small local smoke runs; ingest does not cap discovery.
BOUNDING_BOX=-125,24,-66,50
MAX_CLOUD_FRACTION=0.4

# Processing and tile generation defaults.
PROCESSING_VISIBILITY_TIMEOUT_SECONDS=900
PROCESSING_MAX_DEQUEUE_COUNT=5
PROCESSING_MAX_PARALLELISM=1
RAW_VIIRS_CONTAINER=raw-viirs
PROCESSED_TILES_CONTAINER=processed-tiles
TILE_MIN_ZOOM=3
TILE_MAX_NATIVE_ZOOM=10
TILE_MAX_DISPLAY_ZOOM=12
TILE_SIZE=256
TILE_FORMAT=png
TILE_CLASSIFICATION_VERSION=radiance-dark-sky-v1
TILE_RENDER_VERSION=tiles-v1
# Local manifests should point at Azurite's anonymous blob endpoint. Production
# deployments can omit this variable to use processing-svc's CDN default.
TILE_CDN_BASE_URL=http://127.0.0.1:10000/devstoreaccount1/processed-tiles
TILE_BOUNDS=-125,24,-66,50
TILE_IMMUTABLE_CACHE_CONTROL="public, max-age=31536000, immutable"

# Retention cleanup defaults. `just retention-cleanup` previews selected blobs;
# `just retention-cleanup-execute` deletes selected stale blobs.
RAW_GRANULE_RETENTION_DAYS=90
PROCESSED_TILE_SET_RETENTION_DAYS=180
RETENTION_PROTECTED_PRIOR_TILE_SETS=2
RETENTION_BATCH_LIMIT=500
RETENTION_TILE_BLOB_LIMIT=5000
